# Supabase project credentials.
# Copy this file to .env and fill in the values from your Supabase project
# (Project Settings > API). Never commit the real .env file.

PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SERVER-ONLY Supabase service-role key (Project Settings > API). Used by the
# GREENLINE community-track publish endpoint (/api/greenline-track-publish),
# which must validate submitted tracks in Node before writing — there is no
# client write path to greenline_tracks. Read at runtime via
# $env/dynamic/private, so leaving it blank is safe: publishing responds
# "not configured" and everything else works. NEVER expose this to the client
# and never prefix it PUBLIC_. Set it in the Vercel project env for production.
SUPABASE_SERVICE_ROLE_KEY=

# FSP tech-selection Apps Script endpoint (the /fsp-tech-selection tool posts
# freshman rankings here, and prefills via GET ?email=). Deploy the Google
# Apps Script web app, then paste its /exec URL here. Read at runtime via
# $env/dynamic/public, so leaving it blank is safe: the page loads and the
# picker works, it just shows "saving is not configured yet" instead of posting.
# PLACEHOLDER — replace with the real deployed /exec URL.
PUBLIC_FSP_APPS_SCRIPT_URL=

# FSP Pulse Check Apps Script endpoint (the /fsp-pulse tool posts FRC interest
# + pathway pulse rankings here, and prefills via GET ?email=). Deploy the
# Google Apps Script web app, then paste its /exec URL here. Read at runtime
# via $env/dynamic/public, so leaving it blank is safe: the page loads and the
# picker works, it just shows "saving is not configured yet" instead of posting.
# PLACEHOLDER — replace with the real deployed /exec URL.
PUBLIC_FSP_PULSE_APPS_SCRIPT_URL=
